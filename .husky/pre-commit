# Skip developer pre-commit checks during automated CI commits (e.g. the
# semantic-release version-bump commit). These are not interactive developer
# commits and must not be reformatted or blocked by atomic-commit rules.
if [ "$CI" = "true" ] || [ "$CI" = "1" ]; then
  echo "CI environment detected — skipping interactive pre-commit checks."
  exit 0
fi

echo "Running pre-commit checks..."

# 1. Lint & format staged files (zero-warning ESLint + Prettier).
if ! pnpm exec lint-staged; then
  echo ""
  echo "✖ lint-staged failed. Fix lint/format issues above and re-stage."
  exit 1
fi

# 2. Enforce atomic commits (one logical task per commit).
if ! node scripts/validate-atomic-commit.js; then
  exit 1
fi

echo "Pre-commit checks passed!"
