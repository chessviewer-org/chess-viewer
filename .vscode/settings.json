{
    "javascript.preferences.updateImportsOnFileMove": "always",
    "typescript.preferences.updateImportsOnFileMove": "always",
    "files.watcherExclude": {
        "**/node_modules/**": true,
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/build/**": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/build": true,
        "**/dist": true
    },
    "css.validate": false,
    "less.validate": false,
    "scss.validate": false,
    "files.associations": {
        "*.css": "tailwindcss"
    },
    "editor.quickSuggestions": {
        "strings": true
    },
    "tailwindCSS.experimental.classRegex": [
        [
            "cn\\(([^)]*)\\)",
            "[\"'`]([^\"'`]*).*?[\"'`]"
        ]
    ],
    "tailwindCSS.lint.unknownClass": "ignore",
    "deno.enablePaths": ["supabase/functions"],
    "deno.lint": true,
    "deno.unstable": [],
    "deno.path": "/home/webman/.deno/bin/deno",
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "json.schemas": [
        {
            "fileMatch": ["/supabase/functions/deno.json"],
            "url": "./.vscode/dummy-schema.json"
        }
    ]
}