{
  "name": "chess-viewer",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@chessviewer-org/chess-viewer": "^1.1.0",
    "fflate": "^0.8.3",
    "preact": "^10.29.3",
    "uqr": "^0.1.3",
    "wouter": "^3.10.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "start": "vite",
    "build": "vite build && node scripts/update-csp-hash.mjs && pnpm prerender",
    "build:vite": "vite build",
    "prerender": "node scripts/prerender.mjs",
    "preview": "vite preview",
    "build:analyze": "vite build && npx vite-bundle-visualizer",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:ci": "prettier --check .",
    "test": "node --experimental-strip-types --import ./scripts/register-test-aliases.mjs --test \"src/**/*.test.ts\"",
    "validate": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.39.4",
    "@hono/node-server": "^2.0.11",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "hono": "^4.12.31",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.16",
    "prettier": "^3.8.3",
    "sass": "^1.101.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "1.3.0"
  },
  "optionalDependencies": {
    "puppeteer": "^25.1.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1",
      "node-fetch": "^3.3.2"
    }
  }
}
